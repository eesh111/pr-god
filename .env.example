# ---------------------------------------------------------------------------
# PR Review MCP Server - environment configuration
# Copy this file to .env (which is git-ignored) OR provide these values via
# the "env" block of your Cursor mcp.json entry.
# ---------------------------------------------------------------------------

# --- Personal Access Token auth (default, simplest) ---------------------------
# Classic PAT: needs the "repo" scope (read code + write pull request reviews).
# Fine-grained PAT: needs "Contents: read" + "Pull requests: read and write".
GITHUB_TOKEN=ghp_your_token_here

# --- GitHub App auth (optional alternative) -----------------------------------
# Leave these unset to use GITHUB_TOKEN above. If ALL three are set, the server
# will authenticate as a GitHub App installation instead. Requires installing
# the optional "@octokit/auth-app" package (see README).
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_APP_INSTALLATION_ID=987654

# --- Optional tuning ----------------------------------------------------------
# Max total bytes of diff patch text returned by get_pull_request_diff before
# the response is marked truncated. Defaults to 500000 (~500 KB).
# MAX_DIFF_PATCH_BYTES=500000

# Max bytes for get_file_content when falling back to the Git Blobs API for
# files larger than the Contents API inline limit (~1MB). Defaults to 8 MiB.
# MAX_FILE_CONTENT_BYTES=8388608

# Optional GitHub Enterprise base URL (defaults to https://api.github.com).
# GITHUB_API_BASE_URL=https://github.your-company.com/api/v3

# --- HTTP / dashboard MCP (Automations) ---------------------------------------
# Used by `npm run start:http` (Streamable HTTP on /mcp). Required for Cursor
# Automations — local stdio mcp.json is IDE-only.
# PORT=8787
# HOST=0.0.0.0
# Optional Bearer required by Cursor dashboard clients:
# MCP_HTTP_BEARER=generate_a_long_random_secret
