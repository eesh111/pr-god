{
  "name": "pr-review-mcp",
  "version": "1.1.0",
  "description": "Agent-driven Bugbot: stdio MCP server for GitHub PR I/O. Cursor's agent does all review judgment — no review LLM in this server.",
  "type": "module",
  "bin": {
    "pr-review-mcp": "dist/mcpServer.js"
  },
  "main": "dist/mcpServer.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/mcpServer.js",
    "start:http": "node dist/httpServer.js",
    "dev": "tsc --watch",
    "test": "npm run build && node test/run-all.mjs",
    "test:only": "node test/run-all.mjs",
    "test:mock": "node test/mock-e2e.mjs",
    "test:integration": "node test/integration-mcp.mjs",
    "test:http": "npm run build && node test/http-smoke.mjs",
    "pr-god": "node scripts/run-pr-god-ci.mjs"
  },
  "keywords": [
    "mcp",
    "cursor",
    "github",
    "pull-request",
    "code-review",
    "bugbot"
  ],
  "license": "MIT",
  "dependencies": {
    "@cursor/sdk": "^1.0.23",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@octokit/plugin-retry": "^7.1.2",
    "@octokit/plugin-throttling": "^9.3.2",
    "@octokit/rest": "^21.0.2",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@octokit/auth-app": "^7.1.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2"
  }
}
